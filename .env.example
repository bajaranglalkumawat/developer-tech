NODE_ENV=development
PORT=8080
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority&appName=<app-name>
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_EMAIL=admin@developertech.in
ADMIN_PASSWORD=ChangeThisStrongPassword123!
SITE_URL=http://localhost:8080
PING_MESSAGE=pong

# Email (signup OTP, password reset OTP, legacy link verification, contact form)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Developer Tech

# Google OAuth (optional — email/password signup still works without these)
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID → Web application
# 2. Authorized JavaScript origins (add both local and production):
#      http://localhost:8080
#      https://developertech.in   (or your production SITE_URL origin, no trailing slash)
# 3. Authorized redirect URIs: not required for Google Identity Services (ID token / popup flow)
# 4. Local dev: set GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET (required for token verify).
#    VITE_GOOGLE_CLIENT_ID is optional — the login page also loads the client ID from GET /api/config/public.
# 5. Render/production: set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET only (no rebuild needed).
#    Do not set VITE_GOOGLE_CLIENT_ID on Render unless it matches GOOGLE_CLIENT_ID exactly — the login
#    page always loads the client ID from GET /api/config/public (GOOGLE_CLIENT_ID) to avoid mismatch.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec
